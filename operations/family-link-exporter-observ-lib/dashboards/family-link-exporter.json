    "title": "Family Link Exporter",
    "variables": [
      {
        "kind": "DatasourceVariable",
        "spec": {
          "label": "Data source",
          "name": "datasource",
          "pluginId": "prometheus"
        }
      },
      {
        "kind": "QueryVariable",
        "spec": {
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "includeAll": true,
          "label": "Job",
          "multi": true,
          "name": "job",
          "query": {
            "datasource": {
              "name": "${datasource}"
            },
            "group": "prometheus",
            "kind": "DataQuery",
            "spec": {
              "qryType": 1,
              "query": "label_values(family_link_up, job)",
