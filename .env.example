# Copy to .env and adjust. docker-compose reads these.

# Timezone used to decide which usage sessions count as "today".
FLE_TIMEZONE=Europe/Prague

# --- Optional exporter settings (also settable in docker-compose.yml) ---
# How often to poll the Kids Management API, in seconds.
# FLE_REFRESH_INTERVAL=900
# Restrict to specific child account ids (comma-separated). Empty = all supervised.
# FLE_ACCOUNT_IDS=
# FLE_LOG_LEVEL=INFO

# --- Grafana push for the observ-lib dashboard (`just grafana-push`) ---
# GRAFANA_URL=http://10.13.13.9:3000
# GRAFANA_TOKEN=glsa_xxx        # Grafana service-account token
# GRAFANA_NAMESPACE=default     # org/stack namespace (default: default)
